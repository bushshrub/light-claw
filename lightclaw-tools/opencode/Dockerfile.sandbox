FROM node:20-slim

RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    git curl ca-certificates \
    --no-install-recommends \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN npm install -g opencode-ai@latest

RUN useradd -m -s /bin/bash sandbox

# Writable config dir — entrypoint populates it from the host mount at runtime
RUN mkdir -p /home/sandbox/.config/opencode \
    && chown -R sandbox:sandbox /home/sandbox/.config

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /workspace
RUN chown sandbox:sandbox /workspace

USER sandbox

ENV PYTHONUNBUFFERED=1
ENV NODE_NO_WARNINGS=1

LABEL org.opencontainers.image.title="lightclaw-opencode-sandbox"
LABEL org.opencontainers.image.description="Sandboxed opencode coding agent with Python"

ENTRYPOINT ["/entrypoint.sh"]
