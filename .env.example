# light-claw environment configuration
# Copy to .env and fill in your values

# OpenAI-compatible endpoint (llama.cpp default)
LIGHTCLAW_BASE_URL=http://localhost:8080/v1

# API key — use "local" for llama.cpp, real key for OpenAI/etc.
LIGHTCLAW_API_KEY=local

# Model name as reported by your server
LIGHTCLAW_MODEL=local-model

# SQLite workspace path
# Default: $XDG_CONFIG_HOME/lightclaw/workspace.db (~/.config/lightclaw/workspace.db)
# LIGHTCLAW_DB=/path/to/workspace.db

# Discord bot token (required for: lightclaw discord)
# Create bot at https://discord.com/developers/applications
# Required intents: Message Content, Guild Messages, Direct Messages
# DISCORD_BOT_TOKEN=your_token_here
